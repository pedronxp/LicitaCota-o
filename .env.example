# ─── Banco de dados ─────────────────────────────────────────────────────────────
# Para desenvolvimento local com docker compose, use o valor abaixo.
DATABASE_URL=postgresql://licitapreco:licitapreco@localhost:5432/licitapreco

# ─── Fila BullMQ (Redis) ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ────────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=TROQUE-EM-PRODUCAO-minimo-32-caracteres
JWT_REFRESH_SECRET=TROQUE-EM-PRODUCAO-minimo-32-caracteres-refresh

# Duração dos tokens (formato ms ou strings como '15m', '7d')
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Servidor ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# URL pública do frontend (usado em links de e-mail)
FRONTEND_URL=http://localhost:3000

# ─── E-mail (SMTP) ──────────────────────────────────────────────────────────────
# Deixe em branco para desativar o envio de e-mails.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=usuario@example.com
SMTP_PASS=senha-smtp
SMTP_FROM=LicitaPreço <noreply@example.com>

# ─── Storage de arquivos ────────────────────────────────────────────────────────
# "local" salva em apps/api/uploads/ (padrão para desenvolvimento)
# "supabase" envia ao Supabase Storage
STORAGE_DRIVER=local
STORAGE_BUCKET=licitapreco

# Necessário apenas para STORAGE_DRIVER=supabase
# STORAGE_URL=https://SEU_PROJETO.supabase.co/storage/v1
# STORAGE_KEY=service_role_key_aqui

# ─── Criptografia de credenciais de fontes ──────────────────────────────────────
# Deve ter exatamente 32 bytes. Gere com:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url').slice(0,32))"
CREDENCIAL_ENC_KEY=chave-padrao-dev-troque-em-prod-32b!!

# Retenção e rollout controlado do novo dossiê
EVIDENCE_RAW_RETENTION_DAYS=180
FEATURE_DOSSIE_VERSIONADO=true
# Opcional: IDs de usuários separados por vírgula. Vazio libera para todos quando a feature está ativa.
FEATURE_DOSSIE_PILOT_USERS=
